#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

# Format only staged files to avoid noisy full-repo prettier commits
git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(ts|tsx|js|jsx|json|css|md)$' | xargs npx --no-install prettier --write --ignore-unknown
git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(ts|tsx|js|jsx|json|css|md)$' | xargs git add
